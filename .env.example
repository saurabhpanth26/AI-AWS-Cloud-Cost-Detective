# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT
JWT_SECRET=replace_with_a_long_random_secret

# PostgreSQL (used by docker-compose — no need to set DATABASE_URL manually)
POSTGRES_USER=costdetective
POSTGRES_PASSWORD=costdetective
POSTGRES_DB=costdetective

# AWS credentials (leave blank if using ~/.aws/credentials or an IAM role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
